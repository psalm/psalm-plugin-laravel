<?php

namespace Laravel\Ai;

/**
 * Anonymous-agent factory. Both $instructions (system prompt) and the
 * content of each message in $messages flow into the LLM context.
 *
 * @psalm-taint-sink llm_prompt $instructions
 * @psalm-taint-sink llm_prompt $messages
 */
function agent(
    string $instructions = '',
    iterable $messages = [],
    iterable $tools = [],
    ?\Closure $schema = null,
): \Laravel\Ai\Contracts\Agent {}
