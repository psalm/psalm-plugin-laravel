<?php

namespace Laravel\Ai\Responses;

/**
 * LLM-generated text is untrusted content, similar to user input.
 * An attacker can manipulate the LLM via prompt injection to produce
 * malicious output (XSS payloads, SQL fragments, shell commands).
 *
 * Property-level taint (e.g. $response->text) is handled by
 * LlmOutputTaintHandler because Psalm does not support
 * @psalm-taint-source on properties.
 *
 * @see https://genai.owasp.org/llmrisk/llm01-prompt-injection/ OWASP LLM01:2025
 */
class TextResponse
{
    public string $text;

    /** @psalm-taint-source input */
    public function __toString(): string {}
}
