<?php

namespace Laravel\Ai\Tools;

/**
 * Tool arguments are controlled by the LLM, which can be manipulated
 * via prompt injection to pass malicious values. Treat tool arguments
 * as untrusted input, just like $_GET or Request::input().
 *
 * Parameter types match the untyped signatures from Laravel's
 * InteractsWithData trait — do not add PHP type hints.
 *
 * @see https://genai.owasp.org/llmrisk/llm01-prompt-injection/ OWASP LLM01:2025
 */
class Request
{
    /**
     * @param mixed $keys
     * @return array<string, mixed>
     *
     * @psalm-taint-source input
     */
    public function all($keys = null) {}

    /**
     * @return array<string, mixed>
     *
     * @psalm-taint-source input
     */
    public function toArray(): array {}

    /**
     * @param mixed $offset
     * @return mixed
     *
     * @psalm-taint-source input
     */
    public function offsetGet(mixed $offset): mixed {}

    /**
     * @param string $key
     * @param mixed $default
     * @return \Illuminate\Support\Stringable
     *
     * @psalm-taint-source input
     */
    public function str($key, $default = null) {}

    /**
     * @param string $key
     * @param mixed $default
     * @return \Illuminate\Support\Stringable
     *
     * @psalm-taint-source input
     */
    public function string($key, $default = null) {}

    /**
     * @param string $key
     * @param int $default
     * @return int
     *
     * @psalm-taint-source input
     */
    public function integer($key, $default = 0) {}

    /**
     * @param string $key
     * @param float $default
     * @return float
     *
     * @psalm-taint-source input
     */
    public function float($key, $default = 0.0) {}

    /**
     * @param string|null $key
     * @param bool $default
     * @return bool
     *
     * @psalm-taint-source input
     */
    public function boolean($key = null, $default = false) {}

    /**
     * @param array|string|null $key
     * @return array<array-key, mixed>
     *
     * @psalm-taint-source input
     */
    public function array($key = null) {}

    /**
     * @param array<array-key, string>|string $keys
     * @return array<string, mixed>
     *
     * @psalm-taint-source input
     */
    public function only($keys) {}

    /**
     * @param array<array-key, string>|string $keys
     * @return array<string, mixed>
     *
     * @psalm-taint-source input
     */
    public function except($keys) {}
}
