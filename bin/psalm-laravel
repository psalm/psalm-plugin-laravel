#!/usr/bin/env php
<?php

declare(strict_types=1);

use Psalm\LaravelPlugin\Cli\AddCommand;
use Psalm\LaravelPlugin\Cli\AnalyzeCommand;
use Psalm\LaravelPlugin\Cli\DiagnoseCommand;
use Psalm\LaravelPlugin\Cli\InitCommand;
use Symfony\Component\Console\Application;

// IMPORTANT: try the cwd-relative project autoload FIRST so symlinked plugin
// installations (Composer path repository with `symlink: true`) don't load
// the plugin's own dev autoloader. PHP's __DIR__ resolves through symlinks,
// so falling back to __DIR__-based paths first would pick up the plugin
// source's vendor/, hiding the consuming project's classes (issue #952).
$autoloadCandidates = [
    // Project root vendor: works when invoked from the consuming project root.
    (getcwd() ?: '.') . '/vendor/autoload.php',
    // Installed as a dependency: vendor/psalm/plugin-laravel/bin/psalm-laravel
    __DIR__ . '/../../../autoload.php',
    // Running from a clone of this repo
    __DIR__ . '/../vendor/autoload.php',
];

foreach ($autoloadCandidates as $candidate) {
    if (file_exists($candidate)) {
        require_once $candidate;
        break;
    }
}

if (! class_exists(InitCommand::class)) {
    fwrite(STDERR, "psalm-laravel: could not locate Composer autoloader. Run `composer install` first.\n");
    exit(1);
}

$application = new Application('psalm-laravel');

// Symfony Console: `addCommand()` was added in 7.4 and `add()` was removed in 8.x.
// The cwd-relative autoloader (above) may pull either version from the consuming
// project, so dispatch through the method name that the runtime version exposes.
$register = method_exists($application, 'addCommand') ? 'addCommand' : 'add';
foreach ([new InitCommand(), new AnalyzeCommand(), new AddCommand(), new DiagnoseCommand()] as $command) {
    $application->{$register}($command);
}

// When invoked with no command, pick one based on workspace state: `init` if
// psalm.xml is missing (first-run setup), otherwise `analyze` (everyday use).
$cwd = getcwd();
$hasPsalmConfig = is_string($cwd) && file_exists($cwd . DIRECTORY_SEPARATOR . 'psalm.xml');
$application->setDefaultCommand($hasPsalmConfig ? 'analyze' : 'init');

$application->run();
